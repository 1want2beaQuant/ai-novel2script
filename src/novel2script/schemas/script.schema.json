{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/novel2script/schemas/script.schema.json",
  "title": "Novel2Script YAML Schema",
  "type": "object",
  "required": [
    "schema_version",
    "title",
    "language",
    "generated_at",
    "source",
    "logline",
    "themes",
    "characters",
    "acts",
    "revision_notes"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "required": ["type", "chapter_count", "chapters"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "novel"
        },
        "chapter_count": {
          "type": "integer",
          "minimum": 3
        },
        "chapters": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["index", "title"],
            "additionalProperties": false,
            "properties": {
              "index": {
                "type": "integer",
                "minimum": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "logline": {
      "type": "string",
      "minLength": 1
    },
    "themes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "role", "description", "first_seen_scene"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": ["protagonist", "supporting", "antagonist", "mentor", "minor"]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "first_seen_scene": {
            "type": "string",
            "pattern": "^S\\d{3}$"
          }
        }
      }
    },
    "acts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "purpose", "scenes"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^A\\d+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "scenes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/scene"
            }
          }
        }
      }
    },
    "revision_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "required": [
        "id",
        "title",
        "location",
        "time",
        "summary",
        "source_chapter",
        "characters",
        "beats",
        "blocks"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^S\\d{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "time": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_chapter": {
          "type": "integer",
          "minimum": 1
        },
        "characters": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "beats": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/block"
          }
        }
      }
    },
    "block": {
      "type": "object",
      "required": ["type", "text"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["action", "dialogue", "voice_over", "transition"]
        },
        "character": {
          "type": "string",
          "minLength": 1
        },
        "parenthetical": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "dialogue"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["character"]
          }
        }
      ]
    }
  }
}
