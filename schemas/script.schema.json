{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/novel2script/schemas/script.schema.json",
  "title": "Novel2Script YAML Schema",
  "type": "object",
  "required": [
    "schema_version",
    "title",
    "language",
    "generated_at",
    "source",
    "logline",
    "themes",
    "characters",
    "acts",
    "structure_map",
    "story_bible",
    "adaptation_report",
    "revision_notes"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "required": ["type", "chapter_count", "chapters"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "novel"
        },
        "chapter_count": {
          "type": "integer",
          "minimum": 3
        },
        "chapters": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["index", "title"],
            "additionalProperties": false,
            "properties": {
              "index": {
                "type": "integer",
                "minimum": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "logline": {
      "type": "string",
      "minLength": 1
    },
    "themes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "role", "description", "first_seen_scene"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": ["protagonist", "supporting", "antagonist", "mentor", "minor"]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "first_seen_scene": {
            "type": "string",
            "pattern": "^S\\d{3}$"
          }
        }
      }
    },
    "acts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "purpose", "scenes"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^A\\d+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "scenes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/scene"
            }
          }
        }
      }
    },
    "revision_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "adaptation_report": {
      "type": "object",
      "required": [
        "chapter_coverage",
        "scene_map",
        "metrics",
        "quality_flags",
        "revision_checklist"
      ],
      "additionalProperties": false,
      "properties": {
        "chapter_coverage": {
          "type": "object",
          "required": [
            "total_chapters",
            "adapted_chapters",
            "coverage_ratio",
            "missing_chapters"
          ],
          "additionalProperties": false,
          "properties": {
            "total_chapters": {
              "type": "integer",
              "minimum": 3
            },
            "adapted_chapters": {
              "type": "integer",
              "minimum": 1
            },
            "coverage_ratio": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "missing_chapters": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        },
        "scene_map": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["chapter_index", "chapter_title", "scene_id", "scene_title"],
            "additionalProperties": false,
            "properties": {
              "chapter_index": {
                "type": "integer",
                "minimum": 1
              },
              "chapter_title": {
                "type": "string",
                "minLength": 1
              },
              "scene_id": {
                "type": "string",
                "pattern": "^S\\d{3}$"
              },
              "scene_title": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "metrics": {
          "type": "object",
          "required": [
            "scene_count",
            "block_count",
            "action_blocks",
            "dialogue_blocks",
            "dialogue_ratio"
          ],
          "additionalProperties": false,
          "properties": {
            "scene_count": {
              "type": "integer",
              "minimum": 1
            },
            "block_count": {
              "type": "integer",
              "minimum": 1
            },
            "action_blocks": {
              "type": "integer",
              "minimum": 0
            },
            "dialogue_blocks": {
              "type": "integer",
              "minimum": 0
            },
            "dialogue_ratio": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "quality_flags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "revision_checklist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "structure_map": {
      "type": "object",
      "required": ["model", "beats", "diagnostics"],
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "const": "five_point_screenplay_map"
        },
        "beats": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object",
            "required": [
              "id",
              "label",
              "scene_id",
              "source_chapter",
              "summary",
              "purpose",
              "revision_hint"
            ],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "enum": [
                  "opening_image",
                  "inciting_incident",
                  "midpoint",
                  "climax",
                  "resolution"
                ]
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "scene_id": {
                "type": "string",
                "pattern": "^S\\d{3}$"
              },
              "source_chapter": {
                "type": "integer",
                "minimum": 1
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "purpose": {
                "type": "string",
                "minLength": 1
              },
              "revision_hint": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "diagnostics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "story_bible": {
      "type": "object",
      "required": ["characters", "locations", "props", "open_questions"],
      "additionalProperties": false,
      "properties": {
        "characters": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "role", "first_seen_scene", "continuity_note"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "role": {
                "type": "string",
                "enum": ["protagonist", "supporting", "antagonist", "mentor", "minor"]
              },
              "first_seen_scene": {
                "type": "string",
                "pattern": "^S\\d{3}$"
              },
              "continuity_note": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "locations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "scene_ids", "note"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "scene_ids": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^S\\d{3}$"
                }
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "props": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "source_chapters", "dramatic_function"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "source_chapters": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "dramatic_function": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "open_questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "required": [
        "id",
        "title",
        "location",
        "time",
        "summary",
        "source_chapter",
        "characters",
        "beats",
        "blocks"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^S\\d{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "time": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_chapter": {
          "type": "integer",
          "minimum": 1
        },
        "characters": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "beats": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/block"
          }
        }
      }
    },
    "block": {
      "type": "object",
      "required": ["type", "text"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["action", "dialogue", "voice_over", "transition"]
        },
        "character": {
          "type": "string",
          "minLength": 1
        },
        "parenthetical": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "dialogue"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["character"]
          }
        }
      ]
    }
  }
}
